{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "CGO_ENABLED=0 go build -trimpath -ldflags \"-s -w\" -o /app/proofswe ./cmd/proofswe"
  },
  "deploy": {
    "startCommand": "/app/proofswe serve --addr=:$PORT --judge-provider=openai",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
